#!/usr/bin/env python3

import sys
from pathlib import Path


package_root = Path(__file__).resolve().parent.parent / "lib" / "edgemap-gui"
package_marker = package_root / "edgemap_gui" / "__init__.py"
if not package_marker.is_file():
    raise SystemExit(
        f"edgemap-gui installation is incomplete: missing {package_marker}"
    )
sys.path.insert(0, str(package_root))

from edgemap_gui.app import main


if __name__ == "__main__":
    raise SystemExit(main())
