#compdef dseuhid

_dseuhid() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s \
    '(-c --config-path)'{-c,--config-path}'[Config file path]:config file:_files -g "*.toml"' \
    '(-)1:command:->cmds' \
    && return 0

  case $state in
    cmds)
      _values "dseuhid command" \
        "version[Print version]" \
        "help[Print help]"
      ;;
  esac
}

_dseuhid "$@"
